{
  "store.custom#about-us": {
    "blocks": [
      "flex-layout.row#about-hero",
      "flex-layout.row#about-mission",
      "flex-layout.row#about-cta",
      "flex-layout.row#newsletter"
    ]
  },

  "flex-layout.row#about-hero": {
    "props": {
      "blockClass": "aboutHero",
      "fullWidth": true
    },
    "children": ["flex-layout.col#about-hero-content"]
  },

  "flex-layout.col#about-hero-content": {
    "children": [
      "rich-text#about-title",
      "rich-text#about-subtitle"
    ]
  },

  "rich-text#about-title": {
    "props": {
      "text": "# Sobre a UpNext",
      "textAlignment": "CENTER",
      "textPosition": "CENTER",
      "blockClass": "aboutTitle"
    }
  },

  "rich-text#about-subtitle": {
    "props": {
      "text": "**Moda, estilo e qualidade para quem quer estar sempre à frente**",
      "textAlignment": "CENTER",
      "textPosition": "CENTER",
      "blockClass": "aboutSubtitle"
    }
  },

  "flex-layout.row#about-mission": {
    "props": {
      "blockClass": "aboutMission"
    },
    "children": [
      "flex-layout.col#about-left",
      "flex-layout.col#about-right"
    ]
  },

  "flex-layout.col#about-left": {
    "children": [
      "rich-text#about-mission-title",
      "rich-text#about-mission-text"
    ],
    "props": {
      "blockClass": "aboutColumn"
    }
  },

  "rich-text#about-mission-title": {
    "props": {
      "text": "## Nossa Missão",
      "blockClass": "aboutSectionTitle"
    }
  },

  "rich-text#about-mission-text": {
    "props": {
      "text": "Na UpNext, acreditamos que moda é expressão. Nossa missão é conectar você às melhores marcas e tendências do mercado, com produtos de qualidade, preços acessíveis e uma experiência de compra simples, rápida e segura.\n\nDesde 2020, levamos beleza, estilo e praticidade para milhares de clientes em todo o Brasil.",
      "blockClass": "aboutText"
    }
  },

  "flex-layout.col#about-right": {
    "children": [
      "rich-text#about-values-title",
      "rich-text#about-values-text"
    ],
    "props": {
      "blockClass": "aboutColumn"
    }
  },

  "rich-text#about-values-title": {
    "props": {
      "text": "## Nossos Valores",
      "blockClass": "aboutSectionTitle"
    }
  },

  "rich-text#about-values-text": {
    "props": {
      "text": "- **Qualidade** — Produtos selecionados com critério e cuidado\n- **Transparência** — Preços claros, sem taxas surpresa\n- **Conveniência** — Entrega rápida em todo o Brasil\n- **Segurança** — Compra protegida do início ao fim\n- **Diversidade** — Moda para todos os estilos e ocasiões",
      "blockClass": "aboutText"
    }
  },

  "flex-layout.row#about-cta": {
    "props": {
      "blockClass": "aboutCta",
      "fullWidth": true
    },
    "children": ["rich-text#about-cta-text"]
  },

  "rich-text#about-cta-text": {
    "props": {
      "text": "**Mais de 4 anos conectando pessoas à moda que elas amam.**",
      "textAlignment": "CENTER",
      "textPosition": "CENTER",
      "blockClass": "aboutCtaText"
    }
  }
}
